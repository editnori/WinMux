<UserControl
    x:Class="SelfContainedDeployment.Panes.EditorPaneControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <Grid x:Name="EditorRoot"
          AutomationProperties.AutomationId="editor-pane-root"
          Background="{ThemeResource ShellSurfaceBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="EditorHeader"
                AutomationProperties.AutomationId="editor-pane-header"
                Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                BorderBrush="{ThemeResource ShellBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4,32,4">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="6">
                <TextBlock x:Name="EditorHeaderPathText"
                           AutomationProperties.AutomationId="editor-pane-header-path"
                           FontSize="10.25"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource ShellTextPrimaryBrush}"
                           Text="Editor"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="EditorHeaderMetaText"
                           Grid.Column="1"
                           AutomationProperties.AutomationId="editor-pane-header-meta"
                           FontSize="10.25"
                           Foreground="{ThemeResource ShellTextSecondaryBrush}"
                           Text="Waiting"
                           TextTrimming="CharacterEllipsis" />
                <Button x:Name="EditorPreviousDiffButton"
                        Grid.Column="2"
                        AutomationProperties.AutomationId="editor-pane-header-prev-diff"
                        Click="OnEditorPreviousDiffClicked"
                        Style="{StaticResource ShellDiffNavigationButtonStyle}"
                        ToolTipService.ToolTip="Previous diff section"
                        Visibility="Collapsed">
                    <TextBlock FontSize="10" FontWeight="SemiBold" Text="Prev" />
                </Button>
                <Button x:Name="EditorNextDiffButton"
                        Grid.Column="3"
                        AutomationProperties.AutomationId="editor-pane-header-next-diff"
                        Click="OnEditorNextDiffClicked"
                        Style="{StaticResource ShellDiffNavigationButtonStyle}"
                        ToolTipService.ToolTip="Next diff section"
                        Visibility="Collapsed">
                    <TextBlock FontSize="10" FontWeight="SemiBold" Text="Next" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <WebView2 x:Name="EditorView"
                      AutomationProperties.AutomationId="editor-pane-webview"
                      Margin="0"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />

            <Border x:Name="EditorOverlay"
                    Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                    Visibility="Visible">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="6">
                    <TextBlock x:Name="EditorOverlayTitle"
                               Style="{StaticResource ShellSectionTextStyle}"
                               Text="Loading editor" />
                    <TextBlock x:Name="EditorOverlayText"
                               Style="{StaticResource ShellHintTextStyle}"
                               Text="Preparing the code surface..."
                               TextAlignment="Center"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
