<UserControl
    x:Class="SelfContainedDeployment.Panes.EditorPaneControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <Grid x:Name="EditorRoot"
          AutomationProperties.AutomationId="editor-pane-root"
          Background="{ThemeResource ShellPageBackgroundBrush}">
        <WebView2 x:Name="EditorView"
                  AutomationProperties.AutomationId="editor-pane-webview"
                  Margin="0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" />

        <Border x:Name="EditorOverlay"
                Background="{ThemeResource ShellPageBackgroundBrush}"
                Visibility="Visible">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="6">
                <TextBlock x:Name="EditorOverlayTitle"
                           Style="{StaticResource ShellSectionTextStyle}"
                           Text="Loading editor" />
                <TextBlock x:Name="EditorOverlayText"
                           Style="{StaticResource ShellHintTextStyle}"
                           Text="Preparing the code surface..."
                           TextAlignment="Center"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
