<UserControl
    x:Class="SelfContainedDeployment.Panes.BrowserPaneControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <Grid x:Name="BrowserRoot"
          AutomationProperties.AutomationId="browser-pane-root"
          Background="{ThemeResource ShellSurfaceBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="BrowserChromeBorder"
                Grid.Row="0"
                Canvas.ZIndex="2"
                Background="{ThemeResource BrowserChromeBackgroundBrush}"
                BorderBrush="{ThemeResource BrowserChromeDividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4,32,4">
            <Grid x:Name="BrowserChromeGrid"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="4">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                    <ScrollViewer x:Name="BrowserTabStripScroller"
                                  HorizontalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollBarVisibility="Disabled"
                                  VerticalScrollMode="Disabled"
                                  VerticalAlignment="Center">
                        <StackPanel x:Name="BrowserTabStripPanel"
                                    AutomationProperties.AutomationId="browser-pane-tab-strip"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="0" />
                    </ScrollViewer>

                    <Button x:Name="AddBrowserTabButton"
                            Grid.Column="1"
                            AutomationProperties.AutomationId="browser-pane-add-tab"
                            Style="{StaticResource ShellBrowserToolbarButtonStyle}"
                            Click="OnAddBrowserTabClicked"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Open a new browser tab">
                        <FontIcon FontSize="10.5" Glyph="&#xE710;" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                    <Border Style="{StaticResource ShellBrowserChromeGroupBorderStyle}">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
                              ColumnSpacing="2">
                            <Button x:Name="BrowserBackButton"
                                    AutomationProperties.AutomationId="browser-pane-back"
                                    Style="{StaticResource ShellBrowserGroupedToolbarButtonStyle}"
                                    Click="OnBackClicked"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Go back">
                                <FontIcon FontSize="10.5" Glyph="&#xE72B;" />
                            </Button>

                            <Button x:Name="BrowserForwardButton"
                                    Grid.Column="1"
                                    AutomationProperties.AutomationId="browser-pane-forward"
                                    Style="{StaticResource ShellBrowserGroupedToolbarButtonStyle}"
                                    Click="OnForwardClicked"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Go forward">
                                <FontIcon FontSize="10.5" Glyph="&#xE72A;" />
                            </Button>

                            <Button x:Name="BrowserHomeButton"
                                    Grid.Column="2"
                                    AutomationProperties.AutomationId="browser-pane-home"
                                    Style="{StaticResource ShellBrowserGroupedToolbarButtonStyle}"
                                    Click="OnHomeClicked"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Show browser start page">
                                <FontIcon FontSize="10.5" Glyph="&#xE80F;" />
                            </Button>

                            <Button x:Name="BrowserReloadButton"
                                    Grid.Column="3"
                                    AutomationProperties.AutomationId="browser-pane-reload"
                                    Style="{StaticResource ShellBrowserGroupedToolbarButtonStyle}"
                                    Click="OnReloadClicked"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Reload page">
                                <FontIcon FontSize="10.5" Glyph="&#xE72C;" />
                            </Button>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <TextBox x:Name="AddressBox"
                                 AutomationProperties.AutomationId="browser-pane-address"
                                 Style="{StaticResource ShellBrowserAddressTextBoxStyle}"
                                 VerticalAlignment="Center"
                                 KeyDown="OnAddressBoxKeyDown"
                                 PlaceholderText="Search or enter a URL"
                                 ToolTipService.ToolTip="Search or enter a URL" />
                        <FontIcon Margin="10,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  FontSize="12"
                                  Foreground="{ThemeResource ShellTextTertiaryBrush}"
                                  Glyph="&#xE721;"
                                  IsHitTestVisible="False" />
                    </Grid>

                    <Border Grid.Column="2"
                            Style="{StaticResource ShellBrowserChromeGroupBorderStyle}">
                        <Grid ColumnDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="2">
                            <Button x:Name="BrowserPagesButton"
                                    AutomationProperties.AutomationId="browser-pane-pages"
                                    Style="{StaticResource ShellBrowserGroupedToolbarButtonStyle}"
                                    Click="OnPagesClicked"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Show page and tab details">
                                <FontIcon FontSize="10.5" Glyph="&#xE8A5;" />
                            </Button>

                            <Button x:Name="BrowserExtensionsButton"
                                    Grid.Column="1"
                                    AutomationProperties.AutomationId="browser-pane-extensions"
                                    Style="{StaticResource ShellBrowserGroupedToolbarButtonStyle}"
                                    Click="OnExtensionsClicked"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Show imported extensions">
                                <FontIcon FontSize="10.5" Glyph="&#xE9CE;" />
                            </Button>

                            <Button x:Name="BrowserNewPaneButton"
                                    Grid.Column="2"
                                    AutomationProperties.AutomationId="browser-pane-new-pane"
                                    Style="{StaticResource ShellBrowserGroupedToolbarButtonStyle}"
                                    Click="OnOpenCurrentPageInPaneClicked"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Open this page in another pane">
                                <FontIcon FontSize="10.5" Glyph="&#xE8A7;" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <WebView2 x:Name="BrowserView"
                  Grid.Row="1"
                  Margin="0"
                  Canvas.ZIndex="0"
                  AutomationProperties.AutomationId="browser-pane-webview" />

        <Border x:Name="BrowserResizeMask"
                Grid.Row="1"
                Margin="0"
                Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                Canvas.ZIndex="1"
                IsHitTestVisible="False"
                Opacity="0"
                Visibility="Collapsed" />
    </Grid>
</UserControl>
