    "native:crash-report": "bun tools/native-debugger.mjs crash-report",
    "native:perf:list": "bun tools/native-perf-governor.mjs list",
    "native:perf:check": "bun tools/native-perf-governor.mjs check",
    "native:perf:run": "bun tools/native-perf-governor.mjs run",
