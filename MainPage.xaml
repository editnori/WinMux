<Page
    x:Class="SelfContainedDeployment.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SelfContainedDeployment"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="24,24,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="Native Workspace Shell"
                           Style="{StaticResource SampleHeaderTextStyle}" />
                <TextBlock Text="Project folders, WSL surfaces, Codex threads, Claude Code threads, and browser attachments all live in one native WinUI workspace model."
                           Style="{StaticResource ScenarioDescriptionTextStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Top">
                <Button Content="New WSL Surface"
                        Click="AddWslSession_Click" />
                <Button Content="New Codex Thread"
                        Click="AddCodexSession_Click" />
                <Button Content="New Claude Thread"
                        Click="AddClaudeSession_Click" />
                <Button Content="Attach Browser"
                        Click="AttachBrowserSession_Click" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,0,24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="18"
                        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Margin="0,0,12,0">
                    <Grid RowDefinitions="Auto,*,Auto,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Projects &amp; Workspaces"
                                       Style="{StaticResource ScenarioHeaderTextStyle}" />
                            <TextBlock Text="These are the durable units. Sessions belong to workspaces, not anonymous tabs."
                                       Style="{StaticResource ScenarioDescriptionTextStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ListView x:Name="WorkspaceList"
                                  Grid.Row="1"
                                  Margin="0,16,0,0"
                                  MinHeight="420"
                                  SelectionChanged="WorkspaceList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="4" Margin="0,8,0,8">
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource ScenarioHeaderTextStyle}" />
                                        <TextBlock Text="{Binding FolderName}"
                                                   Style="{StaticResource BaseMessageStyle}" />
                                        <TextBlock Text="{Binding Summary}"
                                                   Style="{StaticResource BaseMessageStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBox x:Name="WorkspaceNameBox"
                                 Grid.Row="2"
                                 Margin="0,16,0,0"
                                 Header="Workspace name" />

                        <Button Grid.Row="3"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Content="Apply Workspace Rename"
                                Click="RenameWorkspace_Click" />
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Padding="18"
                        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Margin="12,0,12,0">
                    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Sessions &amp; Threads"
                                       Style="{StaticResource ScenarioHeaderTextStyle}" />
                            <TextBlock Text="Renameable surfaces make Codex and Claude Code feel closer to project folders than disposable terminal tabs."
                                       Style="{StaticResource ScenarioDescriptionTextStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ListView x:Name="SessionList"
                                  Grid.Row="1"
                                  Margin="0,16,0,0"
                                  MinHeight="320"
                                  SelectionChanged="SessionList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="4" Margin="0,8,0,8">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Style="{StaticResource ScenarioHeaderTextStyle}" />
                                        <TextBlock Text="{Binding KindLabel}"
                                                   Style="{StaticResource BaseMessageStyle}" />
                                        <TextBlock Text="{Binding AttachmentMode}"
                                                   Style="{StaticResource BaseMessageStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBox x:Name="SessionNameBox"
                                 Grid.Row="2"
                                 Margin="0,16,0,0"
                                 Header="Session or thread name" />

                        <Button Grid.Row="3"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Content="Apply Session Rename"
                                Click="RenameSession_Click" />

                        <TextBlock Grid.Row="4"
                                   Margin="0,16,0,0"
                                   Text="Browser surfaces are modeled as sibling workspace attachments so they can slide over the main area later instead of permanently shrinking the terminal."
                                   Style="{StaticResource BaseMessageStyle}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Padding="18"
                        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Margin="12,0,0,0">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*">
                        <TextBlock x:Name="DetailTitleText"
                                   Text="Workspace Preview"
                                   Style="{StaticResource SampleHeaderTextStyle}" />

                        <TextBlock x:Name="WorkspaceMetaText"
                                   Grid.Row="1"
                                   Margin="0,12,0,0"
                                   Style="{StaticResource ScenarioDescriptionTextStyle}"
                                   TextWrapping="Wrap" />

                        <TextBlock x:Name="SessionKindText"
                                   Grid.Row="2"
                                   Margin="0,16,0,0"
                                   Style="{StaticResource ScenarioHeaderTextStyle}" />

                        <TextBlock x:Name="SessionMetaText"
                                   Grid.Row="3"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource ScenarioDescriptionTextStyle}"
                                   TextWrapping="Wrap" />

                        <TextBox x:Name="LaunchCommandBox"
                                 Grid.Row="4"
                                 Margin="0,16,0,0"
                                 Header="Launch command"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="92" />

                        <TextBox x:Name="BehaviorNotesBox"
                                 Grid.Row="5"
                                 Margin="0,16,0,0"
                                 Header="Behavior notes"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="120" />

                        <StackPanel Grid.Row="6"
                                    Margin="0,16,0,0"
                                    Spacing="8">
                            <TextBlock Text="Current build direction"
                                       Style="{StaticResource ScenarioHeaderTextStyle}" />
                            <TextBlock x:Name="DirectionText"
                                       Style="{StaticResource ScenarioDescriptionTextStyle}"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="BrowserModeText"
                                       Style="{StaticResource ScenarioDescriptionTextStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <InfoBar x:Name="infoBar"
                 Grid.Row="2"
                 Margin="24,0,24,24"
                 IsOpen="True"
                 Severity="Informational"
                 Title="Workspace shell ready"
                 Message="Select a workspace or add a new WSL, Codex, Claude, or browser surface." />
    </Grid>
</Page>
