<Page
    x:Class="SelfContainedDeployment.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="ShellRoot" Background="{StaticResource ShellPageBackgroundBrush}">
        <SplitView x:Name="ShellSplitView"
                   CompactPaneLength="52"
                   DisplayMode="CompactInline"
                   IsPaneOpen="True"
                   OpenPaneLength="172"
                   PaneBackground="{StaticResource ShellPaneBackgroundBrush}">
            <SplitView.Pane>
                <Grid Background="{StaticResource ShellPaneBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="8,8,8,6"
                          ColumnDefinitions="28,*"
                          ColumnSpacing="10">
                        <Button x:Name="PaneToggleButton"
                                Style="{StaticResource ShellChromeButtonStyle}"
                                Click="OnPaneToggleClicked"
                                ToolTipService.ToolTip="Collapse sidebar">
                            <FontIcon FontSize="12" Glyph="&#xE700;" />
                        </Button>

                        <TextBlock x:Name="PaneBrandText"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource ShellTitleTextStyle}"
                                   Text="native terminal" />
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="6,4,6,0" Spacing="2">
                        <Button x:Name="TerminalNavButton"
                                Style="{StaticResource ShellNavButtonStyle}"
                                Click="OnTerminalNavClicked"
                                ToolTipService.ToolTip="Show terminal sessions">
                            <Grid ColumnDefinitions="16,*" ColumnSpacing="10">
                                <FontIcon FontSize="12" Glyph="&#xE756;" />
                                <TextBlock x:Name="TerminalNavText"
                                           Grid.Column="1"
                                           FontSize="12"
                                           Text="Terminal" />
                            </Grid>
                        </Button>

                        <Button x:Name="SettingsNavButton"
                                Style="{StaticResource ShellNavButtonStyle}"
                                Click="OnSettingsNavClicked"
                                ToolTipService.ToolTip="Open preferences">
                            <Grid ColumnDefinitions="16,*" ColumnSpacing="10">
                                <FontIcon FontSize="12" Glyph="&#xE713;" />
                                <TextBlock x:Name="SettingsNavText"
                                           Grid.Column="1"
                                           FontSize="12"
                                           Text="Preferences" />
                            </Grid>
                        </Button>
                    </StackPanel>

                    <Button x:Name="NewTabRailButton"
                            Grid.Row="2"
                            Margin="6,0,6,8"
                            Style="{StaticResource ShellNavButtonStyle}"
                            Click="OnNewTabClicked"
                            ToolTipService.ToolTip="Open a new terminal tab">
                        <Grid ColumnDefinitions="16,*" ColumnSpacing="10">
                            <FontIcon FontSize="12" Glyph="&#xE710;" />
                            <TextBlock x:Name="NewTabText"
                                       Grid.Column="1"
                                       FontSize="12"
                                       Text="New tab" />
                        </Grid>
                    </Button>
                </Grid>
            </SplitView.Pane>

            <Grid Background="{StaticResource ShellPageBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Padding="12,0,14,0"
                      Background="{StaticResource ShellSurfaceBackgroundBrush}"
                      BorderBrush="{StaticResource ShellBorderBrush}"
                      BorderThickness="0,0,0,1"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <TextBlock x:Name="WorkspacePathText"
                               VerticalAlignment="Center"
                               Style="{StaticResource ShellMetaTextStyle}"
                               TextTrimming="CharacterEllipsis" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <Ellipse Width="5"
                                 Height="5"
                                 Fill="{StaticResource ShellSuccessBrush}" />
                        <TextBlock Style="{StaticResource ShellHintTextStyle}" Text="ConPTY" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <TabView x:Name="TerminalTabs"
                             AddTabButtonClick="TerminalTabs_AddTabButtonClick"
                             CanDragTabs="True"
                             HorizontalAlignment="Stretch"
                             IsAddTabButtonVisible="True"
                             SelectionChanged="TerminalTabs_SelectionChanged"
                             TabCloseRequested="TerminalTabs_TabCloseRequested"
                             TabWidthMode="SizeToContent"
                             VerticalAlignment="Stretch" />

                    <Frame x:Name="SettingsFrame"
                           Visibility="Collapsed"
                           Background="{StaticResource ShellPageBackgroundBrush}" />
                </Grid>
            </Grid>
        </SplitView>
    </Grid>
</Page>
