<Page
    x:Class="SelfContainedDeployment.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="ShellRoot"
          AutomationProperties.AutomationId="shell-root"
          Background="{ThemeResource ShellPageBackgroundBrush}">
        <SplitView x:Name="ShellSplitView"
                   AutomationProperties.AutomationId="shell-split-view"
                   CompactPaneLength="48"
                   DisplayMode="CompactInline"
                   IsPaneOpen="True"
                   OpenPaneLength="228"
                   PaneBackground="{ThemeResource ShellPaneBackgroundBrush}">
            <SplitView.Pane>
                <Border AutomationProperties.AutomationId="shell-sidebar"
                        Background="{ThemeResource ShellPaneBackgroundBrush}"
                        BorderBrush="{ThemeResource ShellBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border AutomationProperties.AutomationId="shell-sidebar-header"
                                Padding="12,12,12,14"
                                BorderBrush="{ThemeResource ShellBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="28,*"
                                  ColumnSpacing="10">
                                <Button x:Name="PaneToggleButton"
                                        AutomationProperties.AutomationId="shell-pane-toggle"
                                        Style="{StaticResource ShellChromeButtonStyle}"
                                        Click="OnPaneToggleClicked"
                                        ToolTipService.ToolTip="Collapse sidebar">
                                    <FontIcon FontSize="12" Glyph="&#xE700;" />
                                </Button>

                                <TextBlock x:Name="PaneBrandText"
                                           Grid.Column="1"
                                           AutomationProperties.AutomationId="shell-brand-text"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource ShellTitleTextStyle}"
                                           Text="WinMux" />
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      VerticalScrollMode="Auto">
                            <StackPanel Margin="0,10,0,12">
                                <TextBlock x:Name="ProjectSectionText"
                                           Margin="14,0,14,8"
                                           Style="{StaticResource ShellHintTextStyle}"
                                           Text="PROJECTS" />

                                <StackPanel x:Name="ProjectListPanel"
                                            AutomationProperties.AutomationId="shell-project-list"
                                            HorizontalAlignment="Stretch"
                                            Margin="8,0,8,0"
                                            Spacing="10" />
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2"
                                    AutomationProperties.AutomationId="shell-sidebar-footer"
                                    Margin="8,10,8,8"
                                    Spacing="2">
                            <Button x:Name="NewProjectButton"
                                    AutomationProperties.AutomationId="shell-new-project"
                                    Style="{StaticResource ShellNavButtonStyle}"
                                    Click="OnNewProjectClicked"
                                    ToolTipService.ToolTip="Add a new project">
                                <Grid ColumnDefinitions="16,*" ColumnSpacing="10">
                                    <FontIcon FontSize="12" Glyph="&#xE8FA;" />
                                    <TextBlock x:Name="NewProjectText"
                                               Grid.Column="1"
                                               FontSize="12"
                                               Text="New project" />
                                </Grid>
                            </Button>

                            <Button x:Name="SettingsNavButton"
                                    AutomationProperties.AutomationId="shell-nav-settings"
                                    Style="{StaticResource ShellNavButtonStyle}"
                                    Click="OnSettingsNavClicked"
                                    ToolTipService.ToolTip="Open preferences">
                                <Grid ColumnDefinitions="16,*" ColumnSpacing="10">
                                    <FontIcon FontSize="12" Glyph="&#xE713;" />
                                    <TextBlock x:Name="SettingsNavText"
                                               Grid.Column="1"
                                               FontSize="12"
                                               Text="Preferences" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </SplitView.Pane>

            <Grid AutomationProperties.AutomationId="shell-main-content"
                  Background="{ThemeResource ShellPageBackgroundBrush}"
                  Margin="4,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      AutomationProperties.AutomationId="shell-header-bar"
                      Padding="12,6,14,6"
                      Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                      BorderBrush="{ThemeResource ShellBorderBrush}"
                      BorderThickness="0,0,0,1"
                      ColumnDefinitions="*,Auto,*">
                    <TextBox x:Name="ThreadNameBox"
                             AutomationProperties.AutomationId="shell-thread-name"
                             Grid.Column="1"
                             HorizontalAlignment="Center"
                             Style="{StaticResource ShellHeaderInputStyle}"
                             TextChanged="OnThreadNameTextChanged" />

                    <TextBlock x:Name="ActiveDirectoryText"
                               Grid.Column="2"
                               AutomationProperties.AutomationId="shell-active-directory"
                               Margin="14,0,0,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Style="{StaticResource ShellMetaTextStyle}"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <Grid Grid.Row="1"
                      AutomationProperties.AutomationId="shell-workspace-host"
                      Background="{ThemeResource ShellPageBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="InspectorColumn" Width="320" />
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="PaneWorkspaceShell"
                          Grid.Column="0"
                          AutomationProperties.AutomationId="shell-pane-workspace">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              AutomationProperties.AutomationId="shell-pane-strip"
                              Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                              BorderBrush="{ThemeResource ShellBorderBrush}"
                              BorderThickness="0,0,0,1"
                              ColumnDefinitions="*,Auto">
                            <TabView x:Name="TerminalTabs"
                                     AutomationProperties.AutomationId="shell-tab-view"
                                     AddTabButtonClick="TerminalTabs_AddTabButtonClick"
                                     CanDragTabs="True"
                                     Grid.Column="0"
                                     HorizontalAlignment="Stretch"
                                     IsAddTabButtonVisible="True"
                                     SelectionChanged="TerminalTabs_SelectionChanged"
                                     TabCloseRequested="TerminalTabs_TabCloseRequested"
                                     TabWidthMode="SizeToContent"
                                     VerticalAlignment="Stretch" />

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0"
                                        Spacing="6">
                                <Button x:Name="AddBrowserPaneButton"
                                        AutomationProperties.AutomationId="shell-add-browser-pane"
                                        Style="{StaticResource ShellChromeButtonStyle}"
                                        Click="OnAddBrowserPaneClicked"
                                        ToolTipService.ToolTip="Add browser pane">
                                    <FontIcon FontSize="12" Glyph="&#xE774;" />
                                </Button>

                                <Button x:Name="AddEditorPaneButton"
                                        AutomationProperties.AutomationId="shell-add-editor-pane"
                                        Style="{StaticResource ShellChromeButtonStyle}"
                                        Click="OnAddEditorPaneClicked"
                                        ToolTipService.ToolTip="Add editor pane">
                                    <FontIcon FontSize="12" Glyph="&#xE70F;" />
                                </Button>

                                <Button x:Name="ToggleInspectorButton"
                                        AutomationProperties.AutomationId="shell-toggle-inspector"
                                        Style="{StaticResource ShellChromeButtonStyle}"
                                        Click="OnToggleInspectorClicked"
                                        ToolTipService.ToolTip="Hide inspector">
                                    <FontIcon FontSize="12" Glyph="&#xE7F8;" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="PaneWorkspaceGrid"
                              Grid.Row="1"
                              AutomationProperties.AutomationId="shell-pane-grid"
                              Background="{ThemeResource ShellPaneDividerBrush}" />
                    </Grid>

                    <Border Grid.Column="1"
                            x:Name="InspectorSidebar"
                            AutomationProperties.AutomationId="shell-diff-sidebar"
                            Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                            BorderBrush="{ThemeResource ShellBorderBrush}"
                            BorderThickness="1,0,0,0">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Padding="12,10,12,10"
                                  BorderBrush="{ThemeResource ShellBorderBrush}"
                                  BorderThickness="0,0,0,1"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Inspector"
                                               Style="{StaticResource ShellSectionTextStyle}" />
                                    <TextBlock Text="Active thread repo state"
                                               Style="{StaticResource ShellHintTextStyle}" />
                                </StackPanel>

                                <Button x:Name="RefreshDiffButton"
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="shell-diff-refresh"
                                        Click="OnRefreshDiffClicked"
                                        Style="{StaticResource ShellSubItemButtonStyle}">
                                    <Grid ColumnDefinitions="16,*"
                                          ColumnSpacing="8">
                                        <FontIcon FontSize="11"
                                                  Glyph="&#xE72C;" />
                                        <TextBlock Grid.Column="1"
                                                   FontSize="12"
                                                   Text="Refresh" />
                                    </Grid>
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Padding="12,12,12,14"
                                            Spacing="14">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="BRANCH"
                                                   Style="{StaticResource ShellInspectorLabelTextStyle}" />
                                        <TextBlock x:Name="DiffBranchText"
                                                   AutomationProperties.AutomationId="shell-diff-branch"
                                                   Style="{StaticResource ShellBodyTextStyle}"
                                                   Text="No git context" />
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="ROOT"
                                                   Style="{StaticResource ShellInspectorLabelTextStyle}" />
                                        <TextBlock x:Name="DiffWorktreeText"
                                                   AutomationProperties.AutomationId="shell-diff-worktree"
                                                   Style="{StaticResource ShellHintTextStyle}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock x:Name="DiffSummaryText"
                                                   AutomationProperties.AutomationId="shell-diff-summary"
                                                   Style="{StaticResource ShellHintTextStyle}"
                                                   Text="No working tree changes"
                                                   TextWrapping="WrapWholeWords" />
                                        <Border Background="{ThemeResource ShellMutedSurfaceBrush}"
                                                BorderBrush="{ThemeResource ShellBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <ScrollViewer MaxHeight="244"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <StackPanel x:Name="DiffFileListPanel"
                                                            AutomationProperties.AutomationId="shell-diff-file-list"
                                                            Padding="4"
                                                            Spacing="2" />
                                            </ScrollViewer>
                                        </Border>
                                        <TextBlock x:Name="DiffEmptyText"
                                                   Style="{StaticResource ShellHintTextStyle}"
                                                   Text="No changed files in this thread."
                                                   Visibility="Collapsed" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Frame x:Name="SettingsFrame"
                           AutomationProperties.AutomationId="shell-settings-frame"
                           Grid.ColumnSpan="2"
                           Visibility="Collapsed"
                           Background="{ThemeResource ShellPageBackgroundBrush}" />

                    <StackPanel x:Name="EmptyThreadStatePanel"
                                AutomationProperties.AutomationId="shell-empty-thread-state"
                                Grid.ColumnSpan="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed"
                                Spacing="10">
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource ShellSectionTextStyle}"
                                   Text="No threads yet" />
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource ShellHintTextStyle}"
                                   Text="This project is still open. Add a new thread when you want to start working again." />
                        <Button x:Name="EmptyStateNewThreadButton"
                                AutomationProperties.AutomationId="shell-empty-new-thread"
                                HorizontalAlignment="Center"
                                Style="{StaticResource ShellNavButtonStyle}"
                                Click="OnEmptyStateNewThreadClicked">
                            <Grid ColumnDefinitions="16,*" ColumnSpacing="10">
                                <FontIcon FontSize="12" Glyph="&#xE710;" />
                                <TextBlock Grid.Column="1"
                                           FontSize="12"
                                           Text="New thread" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </SplitView>

        <Canvas x:Name="AutomationOverlayCanvas"
                AutomationProperties.AutomationId="shell-automation-overlay"
                Background="Transparent"
                IsHitTestVisible="False"
                Visibility="Collapsed" />
    </Grid>
</Page>
