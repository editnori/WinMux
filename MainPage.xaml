<Page
    x:Class="SelfContainedDeployment.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="ShellRoot"
          AutomationProperties.AutomationId="shell-root"
          Background="{ThemeResource ShellPageBackgroundBrush}">
        <SplitView x:Name="ShellSplitView"
                   AutomationProperties.AutomationId="shell-split-view"
                   CompactPaneLength="48"
                   DisplayMode="CompactInline"
                   IsPaneOpen="True"
                   OpenPaneLength="224"
                   PaneBackground="{ThemeResource ShellPaneBackgroundBrush}">
            <SplitView.Pane>
                <Border AutomationProperties.AutomationId="shell-sidebar"
                        Background="{ThemeResource ShellPaneBackgroundBrush}"
                        BorderBrush="{ThemeResource ShellBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border AutomationProperties.AutomationId="shell-sidebar-header"
                                Padding="8,7,8,6"
                                BorderBrush="{ThemeResource ShellBorderBrush}"
                                BorderThickness="0">
                            <Grid ColumnDefinitions="24,Auto,*"
                                  ColumnSpacing="7">
                                <Button x:Name="PaneToggleButton"
                                        AutomationProperties.AutomationId="shell-pane-toggle"
                                        Style="{StaticResource ShellChromeButtonStyle}"
                                        Click="OnPaneToggleClicked"
                                        ToolTipService.ToolTip="Collapse sidebar">
                                    <FontIcon FontSize="12" Glyph="&#xE700;" />
                                </Button>

                                <Border x:Name="PaneBrandMark"
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="shell-brand-mark"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource ShellMarkBorderStyle}">
                                    <TextBlock Style="{StaticResource ShellMarkTextStyle}" />
                                </Border>

                                <StackPanel x:Name="PaneBrandTextStack"
                                            Grid.Column="2"
                                            Spacing="0"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="PaneBrandText"
                                               AutomationProperties.AutomationId="shell-brand-text"
                                               Style="{StaticResource ShellTitleTextStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               Text="WinMux" />
                                    <TextBlock AutomationProperties.AutomationId="shell-brand-meta"
                                               Style="{StaticResource ShellInteractiveHintTextStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               Text="workspace" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ScrollViewer x:Name="SidebarScrollViewer"
                                      Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      VerticalScrollMode="Auto">
                            <ScrollViewer.Transitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition FromHorizontalOffset="10"
                                                             IsStaggeringEnabled="False" />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ScrollViewer.Transitions>
                            <StackPanel Margin="0,6,0,8">
                                <TextBlock x:Name="ProjectSectionText"
                                           Margin="8,0,8,6"
                                           Style="{StaticResource ShellSidebarSectionTextStyle}"
                                           Text="Projects" />

                                <StackPanel x:Name="ProjectListPanel"
                                            AutomationProperties.AutomationId="shell-project-list"
                                            HorizontalAlignment="Stretch"
                                            Margin="4,0,4,0"
                                            Spacing="4" />
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel x:Name="SidebarFooterStack"
                                    Grid.Row="2"
                                    AutomationProperties.AutomationId="shell-sidebar-footer"
                                    Margin="4,8,4,6"
                                    Spacing="3">
                            <StackPanel.Transitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition FromVerticalOffset="8"
                                                             IsStaggeringEnabled="False" />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </StackPanel.Transitions>
                            <Button x:Name="NewProjectButton"
                                    AutomationProperties.AutomationId="shell-new-project"
                                    Style="{StaticResource ShellSidebarPrimaryButtonStyle}"
                                    Click="OnNewProjectClicked"
                                    ToolTipService.ToolTip="Add a new project">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="6">
                                    <FontIcon FontSize="12" Glyph="&#xE8FA;" />
                                    <TextBlock x:Name="NewProjectText"
                                               FontSize="12"
                                               Text="New project" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="SettingsNavButton"
                                    AutomationProperties.AutomationId="shell-nav-settings"
                                    Style="{StaticResource ShellSidebarPrimaryButtonStyle}"
                                    Click="OnSettingsNavClicked"
                                    ToolTipService.ToolTip="Open preferences">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="6">
                                    <FontIcon FontSize="12" Glyph="&#xE713;" />
                                    <TextBlock x:Name="SettingsNavText"
                                               FontSize="12"
                                               Text="Preferences" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </SplitView.Pane>

                <Grid x:Name="ShellMainContent"
                      AutomationProperties.AutomationId="shell-main-content"
                      Background="{ThemeResource ShellPageBackgroundBrush}"
                      Margin="0">
                    <Grid.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </Grid.Transitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                      AutomationProperties.AutomationId="shell-header-bar"
                      Padding="8,3,10,3"
                      Background="{ThemeResource ShellPageBackgroundBrush}"
                      BorderBrush="Transparent"
                      BorderThickness="0"
                      ColumnDefinitions="*,Auto,*">
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8"
                                MaxWidth="620">
                        <TextBox x:Name="ThreadNameBox"
                                 AutomationProperties.AutomationId="shell-thread-name"
                                 HorizontalAlignment="Center"
                                 MinWidth="180"
                                 MaxWidth="280"
                                 Style="{StaticResource ShellHeaderInputStyle}"
                                 TextChanged="OnThreadNameTextChanged" />

                        <TextBlock x:Name="ActiveDirectorySeparator"
                                   AutomationProperties.AutomationId="shell-active-directory-separator"
                                   Style="{StaticResource ShellHintTextStyle}"
                                   Text="•"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed" />

                        <TextBlock x:Name="ActiveDirectoryText"
                                   AutomationProperties.AutomationId="shell-active-directory"
                                   MaxWidth="300"
                                   HorizontalAlignment="Left"
                                   TextAlignment="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource ShellMetaTextStyle}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      AutomationProperties.AutomationId="shell-workspace-host"
                      Background="{ThemeResource ShellPageBackgroundBrush}">
                    <SplitView x:Name="InspectorSplitView"
                               AutomationProperties.AutomationId="shell-inspector-split-view"
                               CompactPaneLength="0"
                               DisplayMode="CompactInline"
                               IsPaneOpen="True"
                               OpenPaneLength="320"
                               PaneBackground="{ThemeResource ShellSurfaceBackgroundBrush}"
                               PanePlacement="Right">
                        <SplitView.Content>
                            <Grid x:Name="PaneWorkspaceShell"
                                  AutomationProperties.AutomationId="shell-pane-workspace">
                                <Grid.Transitions>
                                    <TransitionCollection>
                                        <RepositionThemeTransition />
                                    </TransitionCollection>
                                </Grid.Transitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      AutomationProperties.AutomationId="shell-pane-strip"
                                      Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                                      BorderBrush="{ThemeResource ShellBorderBrush}"
                                      BorderThickness="0,0,0,1"
                                      ColumnDefinitions="*,Auto">
                                    <TabView x:Name="TerminalTabs"
                                             AutomationProperties.AutomationId="shell-tab-view"
                                             AddTabButtonClick="TerminalTabs_AddTabButtonClick"
                                             CanDragTabs="True"
                                             Grid.Column="0"
                                             HorizontalAlignment="Stretch"
                                             IsAddTabButtonVisible="True"
                                             SelectionChanged="TerminalTabs_SelectionChanged"
                                             TabCloseRequested="TerminalTabs_TabCloseRequested"
                                             TabWidthMode="SizeToContent"
                                             VerticalAlignment="Stretch" />

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0"
                                                Spacing="4">
                                        <Button x:Name="AddBrowserPaneButton"
                                                AutomationProperties.AutomationId="shell-add-browser-pane"
                                                Style="{StaticResource ShellPaneStripButtonStyle}"
                                                Click="OnAddBrowserPaneClicked"
                                                ToolTipService.ToolTip="Add browser pane">
                                            <FontIcon FontSize="11" Glyph="&#xE774;" />
                                        </Button>

                                        <Button x:Name="AddEditorPaneButton"
                                                AutomationProperties.AutomationId="shell-add-editor-pane"
                                                Style="{StaticResource ShellPaneStripButtonStyle}"
                                                Click="OnAddEditorPaneClicked"
                                                ToolTipService.ToolTip="Add editor pane">
                                            <FontIcon FontSize="11" Glyph="&#xE70F;" />
                                        </Button>

                                        <Button x:Name="FitPanesButton"
                                                AutomationProperties.AutomationId="shell-fit-panes"
                                                Style="{StaticResource ShellPaneStripButtonStyle}"
                                                Click="OnFitPanesClicked"
                                                DoubleTapped="OnFitPanesDoubleTapped"
                                                ToolTipService.ToolTip="Fit visible panes">
                                            <FontIcon FontSize="11" Glyph="&#xE9A8;" />
                                        </Button>

                                        <Button x:Name="ToggleInspectorButton"
                                                AutomationProperties.AutomationId="shell-toggle-inspector"
                                                Style="{StaticResource ShellPaneStripButtonStyle}"
                                                Click="OnToggleInspectorClicked"
                                                ToolTipService.ToolTip="Hide inspector">
                                            <FontIcon FontSize="11" Glyph="&#xE7F8;" />
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <Grid x:Name="PaneWorkspaceGrid"
                                      Grid.Row="1"
                                      AutomationProperties.AutomationId="shell-pane-grid"
                                      Background="{ThemeResource ShellPaneDividerBrush}" />

                                <Canvas x:Name="PaneSplitPreviewCanvas"
                                        Grid.Row="1"
                                        AutomationProperties.AutomationId="shell-pane-split-preview"
                                        IsHitTestVisible="False"
                                        Visibility="Collapsed" />
                            </Grid>
                        </SplitView.Content>

                        <SplitView.Pane>
                            <Border x:Name="InspectorSidebar"
                                    AutomationProperties.AutomationId="shell-diff-sidebar"
                                    Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                                    BorderBrush="{ThemeResource ShellBorderBrush}"
                                    BorderThickness="1,0,0,0">
                                <Border.Transitions>
                                    <TransitionCollection>
                                        <EntranceThemeTransition FromHorizontalOffset="20"
                                                                 IsStaggeringEnabled="False" />
                                        <RepositionThemeTransition />
                                    </TransitionCollection>
                                </Border.Transitions>
                                <Grid RowDefinitions="Auto,*">
                                    <Grid Padding="10,9,10,8"
                                          BorderBrush="{ThemeResource ShellBorderBrush}"
                                          BorderThickness="0,0,0,1"
                                          ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="6">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="4"
                                                    VerticalAlignment="Center">
                                            <Button x:Name="InspectorReviewTabButton"
                                                    AutomationProperties.AutomationId="shell-inspector-tab-review"
                                                    Click="OnInspectorReviewTabClicked"
                                                    Style="{StaticResource ShellInspectorTabButtonStyle}"
                                                    Height="28"
                                                    Padding="9,3"
                                                    MinWidth="58">
                                                <TextBlock Text="Review"
                                                           FontSize="11.5" />
                                            </Button>

                                            <Button x:Name="InspectorFilesTabButton"
                                                    AutomationProperties.AutomationId="shell-inspector-tab-files"
                                                    Click="OnInspectorFilesTabClicked"
                                                    Style="{StaticResource ShellInspectorTabButtonStyle}"
                                                    Height="28"
                                                    Padding="9,3"
                                                    MinWidth="48">
                                                <TextBlock Text="Files"
                                                           FontSize="11.5" />
                                            </Button>

                                            <Button x:Name="InspectorNotesTabButton"
                                                    AutomationProperties.AutomationId="shell-inspector-tab-notes"
                                                    Click="OnInspectorNotesTabClicked"
                                                    Style="{StaticResource ShellInspectorTabButtonStyle}"
                                                    Height="28"
                                                    Padding="9,3"
                                                    MinWidth="52">
                                                <TextBlock Text="Notes"
                                                           FontSize="11.5" />
                                            </Button>
                                        </StackPanel>

                                        <StackPanel x:Name="InspectorReviewActionsPanel"
                                                    Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="4"
                                                    VerticalAlignment="Center">
                                            <Button x:Name="OpenFullPatchButton"
                                                    AutomationProperties.AutomationId="shell-open-full-patch"
                                                    Click="OnOpenFullPatchClicked"
                                                    Style="{StaticResource ShellToolbarButtonStyle}"
                                                    ToolTipService.ToolTip="Review all changed files">
                                                <FontIcon FontSize="11"
                                                          Glyph="&#xE8A5;" />
                                            </Button>

                                            <Button x:Name="CaptureCheckpointButton"
                                                    AutomationProperties.AutomationId="shell-diff-capture-checkpoint"
                                                    Click="OnCaptureCheckpointClicked"
                                                    Style="{StaticResource ShellToolbarButtonStyle}"
                                                    ToolTipService.ToolTip="Capture checkpoint">
                                                <FontIcon FontSize="11"
                                                          Glyph="&#xE823;" />
                                            </Button>

                                            <Button x:Name="RefreshDiffButton"
                                                    AutomationProperties.AutomationId="shell-diff-refresh"
                                                    Click="OnRefreshDiffClicked"
                                                    Style="{StaticResource ShellToolbarButtonStyle}"
                                                    ToolTipService.ToolTip="Refresh review">
                                                <FontIcon FontSize="11"
                                                          Glyph="&#xE72C;" />
                                            </Button>
                                        </StackPanel>

                                        <StackPanel x:Name="InspectorFileActionsPanel"
                                                    Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="4"
                                                    VerticalAlignment="Center"
                                                    Visibility="Collapsed">
                                            <Button x:Name="InspectorCollapseAllButton"
                                                    AutomationProperties.AutomationId="shell-directory-collapse-all"
                                                    Click="OnInspectorCollapseAllClicked"
                                                    Style="{StaticResource ShellToolbarButtonStyle}"
                                                    ToolTipService.ToolTip="Collapse all folders">
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Text="−" />
                                            </Button>

                                            <Button x:Name="InspectorSaveFileButton"
                                                    AutomationProperties.AutomationId="shell-editor-save-file"
                                                    Click="OnInspectorSaveFileClicked"
                                                    Style="{StaticResource ShellToolbarButtonStyle}"
                                                    ToolTipService.ToolTip="Save file">
                                                <FontIcon FontSize="11"
                                                          Glyph="&#xE74E;" />
                                            </Button>
                                        </StackPanel>

                                        <StackPanel x:Name="InspectorNotesActionsPanel"
                                                    Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="4"
                                                    VerticalAlignment="Center"
                                                    Visibility="Collapsed">
                                            <Button x:Name="InspectorAddNoteButton"
                                                    AutomationProperties.AutomationId="shell-thread-note-add"
                                                    Click="OnInspectorAddNoteClicked"
                                                    Style="{StaticResource ShellToolbarButtonStyle}"
                                                    ToolTipService.ToolTip="New note">
                                                <FontIcon FontSize="11"
                                                          Glyph="&#xE710;" />
                                            </Button>

                                            <Button x:Name="InspectorDeleteNoteButton"
                                                    AutomationProperties.AutomationId="shell-thread-note-delete"
                                                    Click="OnInspectorDeleteNoteClicked"
                                                    Style="{StaticResource ShellToolbarButtonStyle}"
                                                    ToolTipService.ToolTip="Delete selected note">
                                                <FontIcon FontSize="11"
                                                          Glyph="&#xE74D;" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <Border x:Name="InspectorReviewContent"
                                            Grid.Row="1"
                                            Padding="10,10,10,12">
                                        <Grid RowSpacing="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid x:Name="DiffReviewSourceSection"
                                                  ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="10"
                                                  Visibility="Collapsed">
                                                <TextBlock Text="COMPARE"
                                                           Style="{StaticResource ShellInspectorLabelTextStyle}" />
                                                <StackPanel Grid.Column="1"
                                                            Spacing="4">
                                                    <ComboBox x:Name="DiffReviewSourceComboBox"
                                                              AutomationProperties.AutomationId="shell-diff-review-source"
                                                              SelectionChanged="OnDiffReviewSourceSelectionChanged"
                                                              HorizontalAlignment="Stretch"
                                                              PlaceholderText="Live working tree" />
                                                    <TextBlock x:Name="DiffReviewSourceMetaText"
                                                               AutomationProperties.AutomationId="shell-diff-review-meta"
                                                               Style="{StaticResource ShellHintTextStyle}"
                                                               Text="Live working tree"
                                                               TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="1"
                                                  ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="10"
                                                  RowSpacing="6">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="BRANCH"
                                                           Style="{StaticResource ShellInspectorLabelTextStyle}" />
                                                <TextBlock x:Name="DiffBranchText"
                                                           Grid.Column="1"
                                                           AutomationProperties.AutomationId="shell-diff-branch"
                                                           Style="{StaticResource ShellBodyTextStyle}"
                                                           Text="No git context"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap" />

                                                <TextBlock Grid.Row="1"
                                                           Text="ROOT"
                                                           Style="{StaticResource ShellInspectorLabelTextStyle}" />
                                                <TextBlock x:Name="DiffWorktreeText"
                                                           Grid.Row="1"
                                                           Grid.Column="1"
                                                           AutomationProperties.AutomationId="shell-diff-worktree"
                                                           Style="{StaticResource ShellSidebarMetaTextStyle}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap" />
                                            </Grid>

                                            <TextBlock Grid.Row="2"
                                                       x:Name="DiffSummaryText"
                                                       AutomationProperties.AutomationId="shell-diff-summary"
                                                       Style="{StaticResource ShellSidebarMetaTextStyle}"
                                                       Text="No working tree changes"
                                                       TextWrapping="WrapWholeWords" />

                                            <Grid Grid.Row="3"
                                                  MinHeight="0"
                                                  RowSpacing="8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="CHANGED FILES"
                                                           Style="{StaticResource ShellInspectorLabelTextStyle}" />

                                                <Grid Grid.Row="1"
                                                      MinHeight="0">
                                                    <Grid>
                                                        <ListView x:Name="DiffFileListView"
                                                                  AutomationProperties.AutomationId="shell-diff-file-list"
                                                                  SelectionMode="None"
                                                                  IsItemClickEnabled="False"
                                                                  HorizontalContentAlignment="Stretch"
                                                                  VerticalAlignment="Stretch"
                                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                            <ListView.ItemContainerStyle>
                                                                <Style TargetType="ListViewItem">
                                                                    <Setter Property="Padding" Value="0" />
                                                                    <Setter Property="Margin" Value="0,0,0,2" />
                                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                                </Style>
                                                            </ListView.ItemContainerStyle>
                                                            <ListView.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button Style="{StaticResource ShellDiffFileButtonStyle}"
                                                                            Tag="{Binding File}"
                                                                            HorizontalAlignment="Stretch"
                                                                            HorizontalContentAlignment="Stretch"
                                                                            Click="OnDiffFileButtonClicked"
                                                                            Loaded="OnDiffFileItemButtonLoaded"
                                                                            Unloaded="OnDiffFileItemButtonUnloaded"
                                                                            AutomationProperties.AutomationId="{Binding AutomationId}"
                                                                            AutomationProperties.Name="{Binding AutomationName}">
                                                                        <Grid ColumnSpacing="8">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>

                                                                            <TextBlock Text="{Binding StatusSymbol}"
                                                                                       FontFamily="Consolas"
                                                                                       FontSize="10.25"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{Binding StatusBrush}"
                                                                                       Opacity="0.92"
                                                                                       VerticalAlignment="Top" />

                                                                            <StackPanel Grid.Column="1"
                                                                                        Spacing="1">
                                                                                <TextBlock Text="{Binding FileName}"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock Text="{Binding MetaText}"
                                                                                           FontSize="10.5"
                                                                                           Opacity="0.74"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                            </StackPanel>

                                                                            <StackPanel Grid.Column="2"
                                                                                        Orientation="Horizontal"
                                                                                        Spacing="7"
                                                                                        VerticalAlignment="Top">
                                                                                <TextBlock Text="{Binding AddedText}"
                                                                                           Visibility="{Binding AddedVisibility}"
                                                                                           FontSize="11"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="{ThemeResource ShellSuccessBrush}" />
                                                                                <TextBlock Text="{Binding RemovedText}"
                                                                                           Visibility="{Binding RemovedVisibility}"
                                                                                           FontSize="11"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="{ThemeResource ShellDangerBrush}" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ListView.ItemTemplate>
                                                        </ListView>

                                                        <TextBlock x:Name="DiffEmptyText"
                                                                   VerticalAlignment="Top"
                                                                   Style="{StaticResource ShellHintTextStyle}"
                                                                   Text="No changed files in this thread."
                                                                   Visibility="Collapsed" />
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <ScrollViewer x:Name="InspectorFilesContent"
                                                  Grid.Row="1"
                                                  Visibility="Collapsed"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Padding="8,12,8,14"
                                                    Spacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="DIRECTORY"
                                                           Style="{StaticResource ShellInspectorLabelTextStyle}" />
                                                <TextBlock x:Name="InspectorDirectoryRootText"
                                                           AutomationProperties.AutomationId="shell-directory-root"
                                                           Style="{StaticResource ShellBodyTextStyle}"
                                                           Text="No active project"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap" />
                                                <TextBlock x:Name="InspectorDirectoryMetaText"
                                                           AutomationProperties.AutomationId="shell-directory-meta"
                                                           Style="{StaticResource ShellHintTextStyle}"
                                                           Text="Open an editor pane to browse files."
                                                           TextWrapping="WrapWholeWords" />
                                            </StackPanel>

                                            <TreeView x:Name="InspectorDirectoryTree"
                                                      AutomationProperties.AutomationId="shell-directory-tree"
                                                      DoubleTapped="OnInspectorDirectoryTreeDoubleTapped"
                                                      KeyDown="OnInspectorDirectoryTreeKeyDown"
                                                      Margin="-8,0,0,0"
                                                      SelectionMode="Single">
                                                <TreeView.ItemTemplate>
                                                    <DataTemplate x:DataType="controls:TreeViewNode">
                                                        <ContentPresenter Content="{x:Bind Content}" />
                                                    </DataTemplate>
                                                </TreeView.ItemTemplate>
                                            </TreeView>

                                            <TextBlock x:Name="InspectorDirectoryEmptyText"
                                                       AutomationProperties.AutomationId="shell-directory-empty"
                                                       Style="{StaticResource ShellHintTextStyle}"
                                                       Text="No editable files were found for this thread."
                                                       Visibility="Collapsed"
                                                       TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer x:Name="InspectorNotesContent"
                                                  Grid.Row="1"
                                                  Visibility="Collapsed"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Padding="10,9,10,12"
                                                    Spacing="8">
                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                                  ColumnSpacing="4">
                                                <Button x:Name="InspectorNotesThreadScopeButton"
                                                        AutomationProperties.AutomationId="shell-thread-notes-scope-thread"
                                                        Click="OnInspectorNotesThreadScopeClicked"
                                                        Style="{StaticResource ShellNoteFilterButtonStyle}"
                                                        ToolTipService.ToolTip="Show notes in the current thread"
                                                        Content="Thread" />

                                                <Button x:Name="InspectorNotesProjectScopeButton"
                                                        AutomationProperties.AutomationId="shell-thread-notes-scope-project"
                                                        Grid.Column="1"
                                                        Click="OnInspectorNotesProjectScopeClicked"
                                                        Style="{StaticResource ShellNoteFilterButtonStyle}"
                                                        ToolTipService.ToolTip="Show notes across the current project"
                                                        Content="Project" />

                                                <TextBlock x:Name="InspectorNotesMetaText"
                                                           Grid.Column="2"
                                                           AutomationProperties.AutomationId="shell-thread-notes-meta"
                                                           Style="{StaticResource ShellHintTextStyle}"
                                                           Text="No notes"
                                                           TextAlignment="Right"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />

                                                <Button x:Name="InspectorInlineAddNoteButton"
                                                        AutomationProperties.AutomationId="shell-thread-note-add-inline"
                                                        Grid.Column="3"
                                                        Click="OnInspectorAddNoteClicked"
                                                        Style="{StaticResource ShellGhostToolbarButtonStyle}"
                                                           ToolTipService.ToolTip="Create a new note">
                                                    <FontIcon FontSize="10.5"
                                                              Glyph="&#xE710;" />
                                                </Button>

                                                <Button x:Name="InspectorInlineDeleteNoteButton"
                                                        AutomationProperties.AutomationId="shell-thread-note-delete-inline"
                                                        Grid.Column="4"
                                                        Click="OnInspectorDeleteNoteClicked"
                                                        Style="{StaticResource ShellGhostToolbarButtonStyle}"
                                                        ToolTipService.ToolTip="Delete selected note">
                                                    <FontIcon FontSize="10.5"
                                                              Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>

                                            <TextBlock x:Name="InspectorNotesEmptyText"
                                                       AutomationProperties.AutomationId="shell-thread-note-empty"
                                                       Style="{StaticResource ShellHintTextStyle}"
                                                       Text="No notes in this project."
                                                       Visibility="Collapsed"
                                                       TextWrapping="WrapWholeWords" />

                                            <ItemsControl x:Name="InspectorNotesGroupsItemsControl"
                                                          AutomationProperties.AutomationId="shell-thread-notes">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,12"
                                                                    Spacing="6">
                                                            <Grid Visibility="{Binding HeaderVisibility}"
                                                                  ColumnDefinitions="*,Auto"
                                                                  ColumnSpacing="8">
                                                                <StackPanel Spacing="1">
                                                                    <TextBlock Text="{Binding Title}"
                                                                               Style="{StaticResource ShellSectionTextStyle}"
                                                                               TextTrimming="CharacterEllipsis" />

                                                                    <TextBlock Text="{Binding Meta}"
                                                                               Style="{StaticResource ShellMetaTextStyle}"
                                                                               TextWrapping="WrapWholeWords" />
                                                                </StackPanel>

                                                                <Button Grid.Column="1"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Top"
                                                                        Visibility="{Binding ArchivedSectionVisibility}"
                                                                        Tag="{Binding}"
                                                                        Click="OnInspectorArchivedNotesToggleClicked"
                                                                        Style="{StaticResource ShellInlineActionButtonStyle}"
                                                                        Content="{Binding ArchivedToggleText}" />
                                                            </Grid>

                                                            <ItemsControl ItemsSource="{Binding ActiveNotes}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Margin="0,0,0,8"
                                                                                Tag="{Binding}"
                                                                                Tapped="OnInspectorNoteCardTapped"
                                                                                DoubleTapped="OnInspectorNoteCardDoubleTapped"
                                                                                Padding="0,2,0,6"
                                                                                Background="{Binding CardBackground}"
                                                                                BorderThickness="0"
                                                                                CornerRadius="0">
                                                                            <Grid ColumnDefinitions="Auto,*"
                                                                                  ColumnSpacing="8">
                                                                                <Border Width="2"
                                                                                        Margin="0,1,0,1"
                                                                                        Background="{Binding AccentBrush}"
                                                                                        CornerRadius="999" />

                                                                                <StackPanel Grid.Column="1"
                                                                                            Spacing="3">
                                                                                    <TextBlock Text="{Binding Title}"
                                                                                               FontSize="12"
                                                                                               FontWeight="SemiBold"
                                                                                               MaxLines="2"
                                                                                               TextTrimming="CharacterEllipsis"
                                                                                               TextWrapping="WrapWholeWords" />

                                                                                    <StackPanel Orientation="Horizontal"
                                                                                                Spacing="6">
                                                                                        <Button Tag="{Binding}"
                                                                                                Click="OnInspectorNoteScopeButtonClicked"
                                                                                                Style="{StaticResource ShellNoteTypeButtonStyle}"
                                                                                                Foreground="{Binding AccentBrush}"
                                                                                                ToolTipService.ToolTip="{Binding ScopeToolTip}"
                                                                                                Content="{Binding ScopeButtonLabel}" />

                                                                                        <TextBlock Text="{Binding Meta}"
                                                                                                   Style="{StaticResource ShellMetaTextStyle}"
                                                                                                   TextWrapping="WrapWholeWords"
                                                                                                   VerticalAlignment="Center" />
                                                                                    </StackPanel>

                                                                                    <TextBox Tag="{Binding}"
                                                                                             AutomationProperties.AutomationId="{Binding EditorAutomationId}"
                                                                                             AcceptsReturn="True"
                                                                                             HorizontalAlignment="Stretch"
                                                                                             IsReadOnly="{Binding IsArchived}"
                                                                                             PlaceholderText="{Binding PlaceholderText}"
                                                                                             Style="{StaticResource ShellInspectorNoteCardTextBoxStyle}"
                                                                                             Text="{Binding Text}"
                                                                                             TextChanged="OnInspectorNoteCardTextChanged"
                                                                                             GotFocus="OnInspectorNoteCardTextBoxGotFocus"
                                                                                             KeyDown="OnInspectorNoteCardTextBoxKeyDown"
                                                                                             TextWrapping="Wrap" />

                                                                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                                                                          ColumnSpacing="8">
                                                                                        <TextBlock Text="{Binding TimestampText}"
                                                                                                   Style="{StaticResource ShellHintTextStyle}"
                                                                                                   VerticalAlignment="Center" />

                                                                                        <Button Grid.Column="1"
                                                                                                Tag="{Binding}"
                                                                                                Click="OnInspectorArchiveNoteButtonClicked"
                                                                                                Style="{StaticResource ShellInlineActionButtonStyle}"
                                                                                                Foreground="{Binding AccentBrush}"
                                                                                                ToolTipService.ToolTip="{Binding ArchiveToolTip}"
                                                                                                Visibility="{Binding ArchiveButtonVisibility}"
                                                                                                Content="{Binding ArchiveButtonLabel}" />

                                                                                        <Button Grid.Column="2"
                                                                                                Tag="{Binding}"
                                                                                                Click="OnInspectorDeleteNoteCardClicked"
                                                                                                Style="{StaticResource ShellInlineActionButtonStyle}"
                                                                                                ToolTipService.ToolTip="{Binding DeleteToolTip}"
                                                                                                Content="Delete" />
                                                                                    </Grid>
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <StackPanel Visibility="{Binding ArchivedItemsVisibility}"
                                                                        Spacing="6">
                                                                <ItemsControl ItemsSource="{Binding ArchivedNotes}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Margin="0,0,0,8"
                                                                                    Tag="{Binding}"
                                                                                    Tapped="OnInspectorNoteCardTapped"
                                                                                    DoubleTapped="OnInspectorNoteCardDoubleTapped"
                                                                                    Padding="0,2,0,6"
                                                                                    Background="{Binding CardBackground}"
                                                                                    BorderThickness="0"
                                                                                    CornerRadius="0"
                                                                                    Opacity="0.76">
                                                                                <Grid ColumnDefinitions="Auto,*"
                                                                                      ColumnSpacing="8">
                                                                                    <Border Width="2"
                                                                                            Margin="0,1,0,1"
                                                                                            Background="{Binding AccentBrush}"
                                                                                            CornerRadius="999" />

                                                                                    <StackPanel Grid.Column="1"
                                                                                                Spacing="3">
                                                                                        <TextBlock Text="{Binding Title}"
                                                                                                   FontSize="12"
                                                                                                   FontWeight="SemiBold"
                                                                                                   MaxLines="2"
                                                                                                   TextTrimming="CharacterEllipsis"
                                                                                                   TextWrapping="WrapWholeWords" />

                                                                                        <StackPanel Orientation="Horizontal"
                                                                                                    Spacing="6">
                                                                                            <Button Tag="{Binding}"
                                                                                                    Click="OnInspectorNoteScopeButtonClicked"
                                                                                                    Style="{StaticResource ShellNoteTypeButtonStyle}"
                                                                                                    Foreground="{Binding AccentBrush}"
                                                                                                    ToolTipService.ToolTip="{Binding ScopeToolTip}"
                                                                                                    Content="{Binding ScopeButtonLabel}" />

                                                                                            <TextBlock Text="{Binding Meta}"
                                                                                                       Style="{StaticResource ShellMetaTextStyle}"
                                                                                                       TextWrapping="WrapWholeWords"
                                                                                                       VerticalAlignment="Center" />
                                                                                        </StackPanel>

                                                                                        <TextBox Tag="{Binding}"
                                                                                                 AutomationProperties.AutomationId="{Binding EditorAutomationId}"
                                                                                                 AcceptsReturn="True"
                                                                                                 HorizontalAlignment="Stretch"
                                                                                                 IsReadOnly="{Binding IsArchived}"
                                                                                                 PlaceholderText="{Binding PlaceholderText}"
                                                                                                 Style="{StaticResource ShellInspectorNoteCardTextBoxStyle}"
                                                                                                 Text="{Binding Text}"
                                                                                                 TextChanged="OnInspectorNoteCardTextChanged"
                                                                                                 GotFocus="OnInspectorNoteCardTextBoxGotFocus"
                                                                                                 KeyDown="OnInspectorNoteCardTextBoxKeyDown"
                                                                                                 TextWrapping="Wrap" />

                                                                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                                                                              ColumnSpacing="8">
                                                                                            <TextBlock Text="{Binding TimestampText}"
                                                                                                       Style="{StaticResource ShellHintTextStyle}"
                                                                                                       VerticalAlignment="Center" />

                                                                                            <Button Grid.Column="1"
                                                                                                    Tag="{Binding}"
                                                                                                    Click="OnInspectorArchiveNoteButtonClicked"
                                                                                                    Style="{StaticResource ShellInlineActionButtonStyle}"
                                                                                                    Foreground="{Binding AccentBrush}"
                                                                                                    ToolTipService.ToolTip="{Binding ArchiveToolTip}"
                                                                                                    Visibility="{Binding ArchiveButtonVisibility}"
                                                                                                    Content="{Binding ArchiveButtonLabel}" />

                                                                                            <Button Grid.Column="2"
                                                                                                    Tag="{Binding}"
                                                                                                    Click="OnInspectorDeleteNoteCardClicked"
                                                                                                    Style="{StaticResource ShellInlineActionButtonStyle}"
                                                                                                    ToolTipService.ToolTip="{Binding DeleteToolTip}"
                                                                                                    Content="Delete" />
                                                                                        </Grid>
                                                                                    </StackPanel>
                                                                                </Grid>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </SplitView.Pane>
                    </SplitView>

                    <Frame x:Name="SettingsFrame"
                           AutomationProperties.AutomationId="shell-settings-frame"
                           Visibility="Collapsed"
                           Background="{ThemeResource ShellPageBackgroundBrush}" />

                    <StackPanel x:Name="EmptyThreadStatePanel"
                                AutomationProperties.AutomationId="shell-empty-thread-state"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed"
                                Spacing="10">
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource ShellSectionTextStyle}"
                                   Text="No threads yet" />
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource ShellHintTextStyle}"
                                   Text="This project is still open. Add a new thread when you want to start working again." />
                        <Button x:Name="EmptyStateNewThreadButton"
                                AutomationProperties.AutomationId="shell-empty-new-thread"
                                HorizontalAlignment="Center"
                                Style="{StaticResource ShellNavButtonStyle}"
                                Click="OnEmptyStateNewThreadClicked">
                            <Grid ColumnDefinitions="16,*" ColumnSpacing="10">
                                <FontIcon FontSize="12" Glyph="&#xE710;" />
                                <TextBlock Grid.Column="1"
                                           FontSize="12"
                                           Text="New thread" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </SplitView>

        <Canvas x:Name="AutomationOverlayCanvas"
                AutomationProperties.AutomationId="shell-automation-overlay"
                Background="Transparent"
                IsHitTestVisible="False"
                Visibility="Collapsed" />

        <Border x:Name="ShellThemeTransitionOverlay"
                AutomationProperties.AutomationId="shell-theme-transition-overlay"
                Background="{ThemeResource ShellPageBackgroundBrush}"
                IsHitTestVisible="False"
                Opacity="0"
                Visibility="Collapsed" />
    </Grid>
</Page>
