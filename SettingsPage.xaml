<Page
    x:Class="SelfContainedDeployment.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid AutomationProperties.AutomationId="settings-root"
          Background="{ThemeResource ShellPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="SettingsNarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                </VisualState>

                <VisualState x:Name="SettingsWideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="920" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="AppearanceSectionLabelColumn.Width" Value="156" />
                        <Setter Target="AppearanceSectionContentColumn.Width" Value="*" />
                        <Setter Target="AppearanceSectionContent.(Grid.Row)" Value="0" />
                        <Setter Target="AppearanceSectionContent.(Grid.Column)" Value="1" />

                        <Setter Target="ShellSectionLabelColumn.Width" Value="156" />
                        <Setter Target="ShellSectionContentColumn.Width" Value="*" />
                        <Setter Target="ShellSectionContent.(Grid.Row)" Value="0" />
                        <Setter Target="ShellSectionContent.(Grid.Column)" Value="1" />

                        <Setter Target="PaneLimitSectionLabelColumn.Width" Value="156" />
                        <Setter Target="PaneLimitSectionContentColumn.Width" Value="*" />
                        <Setter Target="PaneLimitSectionContent.(Grid.Row)" Value="0" />
                        <Setter Target="PaneLimitSectionContent.(Grid.Column)" Value="1" />

                        <Setter Target="VaultSectionLabelColumn.Width" Value="156" />
                        <Setter Target="VaultSectionContentColumn.Width" Value="*" />
                        <Setter Target="VaultSectionContent.(Grid.Row)" Value="0" />
                        <Setter Target="VaultSectionContent.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto">
            <StackPanel Margin="24,18,24,24"
                        MaxWidth="940"
                        Spacing="20"
                        HorizontalAlignment="Center">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                    <Border VerticalAlignment="Top"
                            Style="{StaticResource ShellMarkBorderStyle}">
                        <TextBlock Style="{StaticResource ShellMarkTextStyle}" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Spacing="4">
                        <TextBlock Style="{StaticResource ShellSectionTextStyle}" Text="Preferences" />
                        <TextBlock Style="{StaticResource ShellHintTextStyle}"
                                   Text="Theme, shell defaults, pane density, and browser vault." />
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="18">
                    <Grid x:Name="AppearanceSectionGrid"
                          RowSpacing="6"
                          ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="AppearanceSectionLabelColumn" Width="*" />
                            <ColumnDefinition x:Name="AppearanceSectionContentColumn" Width="0" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    x:Name="AppearanceSectionLabel"
                                    Spacing="2">
                            <TextBlock Style="{StaticResource ShellPreferenceGroupLabelTextStyle}" Text="Appearance" />
                            <TextBlock Style="{StaticResource ShellPreferenceGroupMetaTextStyle}" Text="Chrome + terminal" />
                        </StackPanel>

                        <StackPanel x:Name="AppearanceSectionContent"
                                    Grid.Row="1"
                                    Spacing="4">
                            <StackPanel x:Name="themePanel"
                                        Spacing="4">
                                <RadioButton AutomationProperties.AutomationId="settings-theme-light"
                                             Style="{StaticResource ShellPreferenceRadioButtonStyle}"
                                             Checked="OnThemeRadioButtonChecked">
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionTitleTextStyle}" Text="Light" />
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionHintTextStyle}"
                                                   Text="Cool, flat surfaces." />
                                    </StackPanel>
                                    <RadioButton.Tag>
                                        <ElementTheme>Light</ElementTheme>
                                    </RadioButton.Tag>
                                </RadioButton>

                                <RadioButton AutomationProperties.AutomationId="settings-theme-dark"
                                             Style="{StaticResource ShellPreferenceRadioButtonStyle}"
                                             Checked="OnThemeRadioButtonChecked">
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionTitleTextStyle}" Text="Dark" />
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionHintTextStyle}"
                                                   Text="Low glare for terminal-heavy work." />
                                    </StackPanel>
                                    <RadioButton.Tag>
                                        <ElementTheme>Dark</ElementTheme>
                                    </RadioButton.Tag>
                                </RadioButton>

                                <RadioButton AutomationProperties.AutomationId="settings-theme-default"
                                             Style="{StaticResource ShellPreferenceRadioButtonStyle}"
                                             Checked="OnThemeRadioButtonChecked">
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionTitleTextStyle}" Text="System default" />
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionHintTextStyle}"
                                                   Text="Follow Windows automatically." />
                                    </StackPanel>
                                    <RadioButton.Tag>
                                        <ElementTheme>Default</ElementTheme>
                                    </RadioButton.Tag>
                                </RadioButton>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="ShellSectionGrid"
                          RowSpacing="6"
                          ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ShellSectionLabelColumn" Width="*" />
                            <ColumnDefinition x:Name="ShellSectionContentColumn" Width="0" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    x:Name="ShellSectionLabel"
                                    Spacing="2">
                            <TextBlock Style="{StaticResource ShellPreferenceGroupLabelTextStyle}" Text="Default shell" />
                            <TextBlock Style="{StaticResource ShellPreferenceGroupMetaTextStyle}" Text="New projects + tabs" />
                        </StackPanel>

                        <StackPanel x:Name="ShellSectionContent"
                                    Grid.Row="1"
                                    Spacing="4">
                            <StackPanel x:Name="shellProfilePanel"
                                        Spacing="4">
                                <RadioButton x:Name="CommandPromptShellRadio"
                                             AutomationProperties.AutomationId="settings-shell-cmd"
                                             Style="{StaticResource ShellPreferenceRadioButtonStyle}"
                                             Checked="OnShellProfileRadioButtonChecked"
                                             Tag="cmd">
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionTitleTextStyle}" Text="Command Prompt" />
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionHintTextStyle}"
                                                   Text="Classic Windows shell." />
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton x:Name="PowerShellRadio"
                                             AutomationProperties.AutomationId="settings-shell-powershell"
                                             Style="{StaticResource ShellPreferenceRadioButtonStyle}"
                                             Checked="OnShellProfileRadioButtonChecked"
                                             Tag="powershell">
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionTitleTextStyle}" Text="PowerShell" />
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionHintTextStyle}"
                                                   Text="Windows scripting with WinMux chrome." />
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton x:Name="WslShellRadio"
                                             AutomationProperties.AutomationId="settings-shell-wsl"
                                             Style="{StaticResource ShellPreferenceRadioButtonStyle}"
                                             Checked="OnShellProfileRadioButtonChecked"
                                             Tag="wsl">
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionTitleTextStyle}" Text="WSL" />
                                        <TextBlock Style="{StaticResource ShellPreferenceOptionHintTextStyle}"
                                                   Text="Start inside translated Linux paths." />
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="PaneLimitSectionGrid"
                          RowSpacing="6"
                          ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="PaneLimitSectionLabelColumn" Width="*" />
                            <ColumnDefinition x:Name="PaneLimitSectionContentColumn" Width="0" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    x:Name="PaneLimitSectionLabel"
                                    Spacing="2">
                            <TextBlock Style="{StaticResource ShellPreferenceGroupLabelTextStyle}" Text="Pane limit" />
                            <TextBlock Style="{StaticResource ShellPreferenceGroupMetaTextStyle}" Text="Thread density" />
                        </StackPanel>

                        <StackPanel x:Name="PaneLimitSectionContent"
                                    Grid.Row="1"
                                    Spacing="6">
                            <ComboBox x:Name="paneLimitBox"
                                      AutomationProperties.AutomationId="settings-pane-limit"
                                      HorizontalAlignment="Left"
                                      Style="{StaticResource ShellPreferenceComboBoxStyle}"
                                      SelectedIndex="2"
                                      SelectionChanged="OnPaneLimitSelectionChanged">
                                <ComboBoxItem Content="2 panes" Tag="2" />
                                <ComboBoxItem Content="3 panes" Tag="3" />
                                <ComboBoxItem Content="4 panes" Tag="4" />
                            </ComboBox>

                            <TextBlock Style="{StaticResource ShellPreferenceOptionHintTextStyle}"
                                       Text="Open a new thread instead of crushing the current workspace." />
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="VaultSectionGrid"
                          RowSpacing="6"
                          ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="VaultSectionLabelColumn" Width="*" />
                            <ColumnDefinition x:Name="VaultSectionContentColumn" Width="0" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    x:Name="VaultSectionLabel"
                                    Spacing="2">
                            <TextBlock Style="{StaticResource ShellPreferenceGroupLabelTextStyle}" Text="Browser vault" />
                            <TextBlock Style="{StaticResource ShellPreferenceGroupMetaTextStyle}" Text="Imported logins" />
                        </StackPanel>

                        <StackPanel x:Name="VaultSectionContent"
                                    Grid.Row="1"
                                    Spacing="8">
                            <TextBlock Style="{StaticResource ShellPreferenceOptionHintTextStyle}"
                                       Text="Separate from WebView2 passwords and Chrome Sync." />

                            <StackPanel Orientation="Horizontal"
                                        Spacing="10">
                                <Button x:Name="ImportBrowserCredentialsButton"
                                        AutomationProperties.AutomationId="settings-browser-import"
                                        Style="{StaticResource ShellInlineActionButtonStyle}"
                                        Click="OnImportBrowserCredentialsClicked"
                                        Content="Import CSV" />

                                <Button x:Name="AutofillCurrentBrowserButton"
                                        AutomationProperties.AutomationId="settings-browser-autofill"
                                        Style="{StaticResource ShellInlineActionButtonStyle}"
                                        Click="OnAutofillCurrentBrowserClicked"
                                        Content="Autofill page" />

                                <Button x:Name="ClearBrowserCredentialsButton"
                                        AutomationProperties.AutomationId="settings-browser-clear"
                                        Style="{StaticResource ShellInlineActionButtonStyle}"
                                        Click="OnClearBrowserCredentialsClicked"
                                        Content="Clear vault" />
                            </StackPanel>

                            <TextBlock x:Name="browserCredentialStatusText"
                                       AutomationProperties.AutomationId="settings-browser-credential-status"
                                       Style="{StaticResource ShellPreferenceStatusTextStyle}"
                                       Text="No imported browser credentials yet." />

                            <ScrollViewer MaxHeight="320"
                                          VerticalScrollBarVisibility="Auto"
                                          VerticalScrollMode="Auto">
                                <StackPanel x:Name="browserCredentialListPanel"
                                            AutomationProperties.AutomationId="settings-browser-credential-list"
                                            Spacing="4" />
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <TextBlock Grid.Row="1"
                   Margin="24,0,24,14"
                   Style="{StaticResource ShellHintTextStyle}"
                   Text="Existing tabs keep their shell. New tabs use this default." />
    </Grid>
</Page>
