<Page
    x:Class="SelfContainedDeployment.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid AutomationProperties.AutomationId="settings-root"
          Background="{ThemeResource ShellPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0">
            <StackPanel Margin="24,24,24,24" Spacing="28">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource ShellSectionTextStyle}" Text="Appearance" />
                    <TextBlock Style="{StaticResource ShellHintTextStyle}"
                               Text="Keep the shell monochrome and quiet. Theme changes apply to the native chrome and the terminal host." />
                </StackPanel>

                <StackPanel x:Name="themePanel" Spacing="8">
                    <RadioButton AutomationProperties.AutomationId="settings-theme-light"
                                 Checked="OnThemeRadioButtonChecked"
                                 Content="Light">
                        <RadioButton.Tag>
                            <ElementTheme>Light</ElementTheme>
                        </RadioButton.Tag>
                    </RadioButton>
                    <RadioButton AutomationProperties.AutomationId="settings-theme-dark"
                                 Checked="OnThemeRadioButtonChecked"
                                 Content="Dark">
                        <RadioButton.Tag>
                            <ElementTheme>Dark</ElementTheme>
                        </RadioButton.Tag>
                    </RadioButton>
                    <RadioButton AutomationProperties.AutomationId="settings-theme-default"
                                 Checked="OnThemeRadioButtonChecked"
                                 Content="System default">
                        <RadioButton.Tag>
                            <ElementTheme>Default</ElementTheme>
                        </RadioButton.Tag>
                    </RadioButton>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource ShellSectionTextStyle}" Text="Default shell" />
                    <TextBlock Style="{StaticResource ShellHintTextStyle}"
                               Text="New projects and new tabs use this profile. WSL projects start in the translated Linux path so `/mnt/...` sessions land where you expect." />
                </StackPanel>

                <StackPanel x:Name="shellProfilePanel" Spacing="8">
                    <RadioButton x:Name="CommandPromptShellRadio"
                                 AutomationProperties.AutomationId="settings-shell-cmd"
                                 Checked="OnShellProfileRadioButtonChecked"
                                 Content="Command Prompt"
                                 Tag="cmd" />
                    <RadioButton x:Name="PowerShellRadio"
                                 AutomationProperties.AutomationId="settings-shell-powershell"
                                 Checked="OnShellProfileRadioButtonChecked"
                                 Content="PowerShell"
                                 Tag="powershell" />
                    <RadioButton x:Name="WslShellRadio"
                                 AutomationProperties.AutomationId="settings-shell-wsl"
                                 Checked="OnShellProfileRadioButtonChecked"
                                 Content="WSL"
                                 Tag="wsl" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource ShellSectionTextStyle}" Text="Thread pane limit" />
                    <TextBlock Style="{StaticResource ShellHintTextStyle}"
                               Text="When a thread reaches this pane count, new panes spill into a new thread instead of shrinking the current workspace further." />
                </StackPanel>

                <ComboBox x:Name="paneLimitBox"
                          AutomationProperties.AutomationId="settings-pane-limit"
                          HorizontalAlignment="Left"
                          MinWidth="160"
                          SelectedIndex="2"
                          SelectionChanged="OnPaneLimitSelectionChanged">
                    <ComboBoxItem Content="2 panes" Tag="2" />
                    <ComboBoxItem Content="3 panes" Tag="3" />
                    <ComboBoxItem Content="4 panes" Tag="4" />
                </ComboBox>

                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource ShellSectionTextStyle}" Text="Browser credentials" />
                    <TextBlock Style="{StaticResource ShellHintTextStyle}"
                               Text="WinMux keeps imported browser credentials in an encrypted app vault. This is separate from WebView2's native password manager and separate from Chrome Sync." />
                </StackPanel>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Button x:Name="ImportBrowserCredentialsButton"
                            AutomationProperties.AutomationId="settings-browser-import"
                            Style="{StaticResource ShellNavButtonStyle}"
                            Background="{ThemeResource ShellMutedSurfaceBrush}"
                            BorderBrush="{ThemeResource ShellBorderBrush}"
                            Click="OnImportBrowserCredentialsClicked"
                            Content="Import CSV" />

                    <Button x:Name="AutofillCurrentBrowserButton"
                            Grid.Column="1"
                            AutomationProperties.AutomationId="settings-browser-autofill"
                            Style="{StaticResource ShellNavButtonStyle}"
                            Background="{ThemeResource ShellMutedSurfaceBrush}"
                            BorderBrush="{ThemeResource ShellBorderBrush}"
                            Click="OnAutofillCurrentBrowserClicked"
                            Content="Autofill current page" />

                    <Button x:Name="ClearBrowserCredentialsButton"
                            Grid.Column="2"
                            AutomationProperties.AutomationId="settings-browser-clear"
                            Style="{StaticResource ShellNavButtonStyle}"
                            Background="{ThemeResource ShellMutedSurfaceBrush}"
                            BorderBrush="{ThemeResource ShellBorderBrush}"
                            Click="OnClearBrowserCredentialsClicked"
                            Content="Clear vault" />
                </Grid>

                <TextBlock x:Name="browserCredentialStatusText"
                           AutomationProperties.AutomationId="settings-browser-credential-status"
                           Style="{StaticResource ShellHintTextStyle}"
                           Text="No imported browser credentials yet." />

                <Border BorderBrush="{ThemeResource ShellBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10">
                    <ScrollViewer MaxHeight="260"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Auto">
                        <StackPanel x:Name="browserCredentialListPanel"
                                    AutomationProperties.AutomationId="settings-browser-credential-list"
                                    Spacing="8" />
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Padding="24,12"
                BorderBrush="{ThemeResource ShellBorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Style="{StaticResource ShellHintTextStyle}"
                       Text="Existing tabs keep their current shell. New tabs follow the selected profile." />
        </Border>
    </Grid>
</Page>
