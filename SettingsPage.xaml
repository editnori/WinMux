<Page
    x:Class="SelfContainedDeployment.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ShellPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24,20,24,16"
                Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                BorderBrush="{ThemeResource ShellBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource ShellSectionTextStyle}" Text="Preferences" />
                <TextBlock Style="{StaticResource ShellHintTextStyle}"
                           Text="Keep the chrome quiet. Use the settings to tune only what changes behavior." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="24,20,24,20" Spacing="24">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource ShellSectionTextStyle}" Text="Appearance" />
                    <TextBlock Style="{StaticResource ShellHintTextStyle}"
                               Text="Pick the theme for the shell chrome and terminal host." />
                </StackPanel>

                <StackPanel x:Name="themePanel" Spacing="8">
                    <RadioButton AutomationProperties.AutomationId="settings-theme-light"
                                 Checked="OnThemeRadioButtonChecked"
                                 Content="Light">
                        <RadioButton.Tag>
                            <ElementTheme>Light</ElementTheme>
                        </RadioButton.Tag>
                    </RadioButton>
                    <RadioButton AutomationProperties.AutomationId="settings-theme-dark"
                                 Checked="OnThemeRadioButtonChecked"
                                 Content="Dark">
                        <RadioButton.Tag>
                            <ElementTheme>Dark</ElementTheme>
                        </RadioButton.Tag>
                    </RadioButton>
                    <RadioButton AutomationProperties.AutomationId="settings-theme-default"
                                 Checked="OnThemeRadioButtonChecked"
                                 Content="System default">
                        <RadioButton.Tag>
                            <ElementTheme>Default</ElementTheme>
                        </RadioButton.Tag>
                    </RadioButton>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="24,12"
                BorderBrush="{ThemeResource ShellBorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Style="{StaticResource ShellHintTextStyle}"
                       Text="Theme changes apply to the native shell and the embedded terminal surface." />
        </Border>
    </Grid>
</Page>
