<UserControl
    x:Class="SelfContainedDeployment.Terminal.TerminalControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <Grid x:Name="TerminalRoot"
          AutomationProperties.AutomationId="terminal-root"
          Background="{ThemeResource ShellPageBackgroundBrush}">
        <WebView2 x:Name="TerminalView"
                  AutomationProperties.AutomationId="terminal-webview" />

        <Border x:Name="StartupMask"
                AutomationProperties.AutomationId="terminal-startup-mask"
                Background="{ThemeResource ShellPageBackgroundBrush}">
            <Grid>
                <Border MaxWidth="360"
                        Padding="18,16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource ShellMutedSurfaceBrush}"
                        BorderBrush="{ThemeResource ShellBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel Spacing="10">
                        <ProgressRing x:Name="StartupProgressRing"
                                      Width="24"
                                      Height="24"
                                      HorizontalAlignment="Left"
                                      IsActive="True" />
                        <TextBlock x:Name="StartupTitleText"
                                   Style="{StaticResource ShellSectionTextStyle}"
                                   Text="Starting terminal" />
                        <TextBlock x:Name="StartupDetailText"
                                   Style="{StaticResource ShellHintTextStyle}"
                                   TextWrapping="WrapWholeWords"
                                   Text="/mnt/c/Users/lqassem/native-terminal-starter" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="StatusBadge"
                AutomationProperties.AutomationId="terminal-status-badge"
                Margin="16"
                Padding="10,6"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="{ThemeResource ShellMutedSurfaceBrush}"
                BorderBrush="{ThemeResource ShellBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Visibility="Collapsed">
            <TextBlock x:Name="StatusText"
                       Style="{StaticResource ShellMetaTextStyle}"
                       Text="Starting terminal…" />
        </Border>
    </Grid>
</UserControl>
