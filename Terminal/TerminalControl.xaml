<UserControl
    x:Class="SelfContainedDeployment.Terminal.TerminalControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <Grid Background="{ThemeResource ShellPageBackgroundBrush}">
        <WebView2 x:Name="TerminalView" />

        <Border x:Name="StatusBadge"
                Margin="16"
                Padding="10,6"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="{ThemeResource ShellMutedSurfaceBrush}"
                BorderBrush="{ThemeResource ShellBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <TextBlock x:Name="StatusText"
                       Style="{StaticResource ShellMetaTextStyle}"
                       Text="Starting terminal…" />
        </Border>
    </Grid>
</UserControl>
