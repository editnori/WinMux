<UserControl
    x:Class="SelfContainedDeployment.Terminal.TerminalControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <Grid x:Name="TerminalRoot"
          AutomationProperties.AutomationId="terminal-root"
          Background="{ThemeResource ShellSurfaceBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="TerminalHeader"
                AutomationProperties.AutomationId="terminal-header"
                Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                BorderBrush="{ThemeResource ShellBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,1,28,2">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <TextBlock x:Name="TerminalHeaderTitleText"
                           AutomationProperties.AutomationId="terminal-header-title"
                           FontSize="10.25"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource ShellTextPrimaryBrush}"
                           Text="Terminal"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="TerminalHeaderMetaText"
                           Grid.Column="1"
                           AutomationProperties.AutomationId="terminal-header-meta"
                           FontSize="10"
                           Foreground="{ThemeResource ShellTextSecondaryBrush}"
                           Text="Preparing shell"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              x:Name="TerminalContentHost">
            <Border x:Name="NativeTerminalViewport"
                    Margin="8,6,8,8"
                    Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                    BorderBrush="{ThemeResource ShellBorderBrush}"
                    BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                    <Border x:Name="ToolSessionRail"
                            Grid.Column="0"
                            Width="3"
                            Margin="0,10,8,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="#E05A5A"
                            CornerRadius="1.5"
                            Opacity="0"
                            Visibility="Collapsed" />

                    <Grid x:Name="NativeTerminalHost"
                          Grid.Column="1"
                          Margin="10,8,10,10"
                          AutomationProperties.AutomationId="terminal-webview" />
                </Grid>
            </Border>

            <Border x:Name="StartupMask"
                    AutomationProperties.AutomationId="terminal-startup-mask"
                    Background="{ThemeResource ShellSurfaceBackgroundBrush}">
                <Grid>
                    <StackPanel MaxWidth="420"
                                Margin="18,18,18,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Spacing="9">
                        <TextBlock x:Name="StartupKickerText"
                                   Style="{StaticResource ShellInspectorLabelTextStyle}"
                                   Text="Terminal workspace" />
                        <StackPanel Spacing="3">
                            <TextBlock x:Name="StartupTitleText"
                                       Style="{StaticResource ShellSectionTextStyle}"
                                       Text="Starting terminal" />
                            <TextBlock x:Name="StartupDetailText"
                                       Style="{StaticResource ShellHintTextStyle}"
                                       TextWrapping="WrapWholeWords"
                                       Text="/mnt/c/Users/lqassem/native-terminal-starter" />
                        </StackPanel>
                        <Border Height="1"
                                Width="88"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource ShellBorderBrush}" />
                        <TextBlock x:Name="StartupMetaText"
                                   Style="{StaticResource ShellInteractiveHintTextStyle}"
                                   Text="Preparing terminal host, shell bridge, and replay state." />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="StatusBadge"
                    AutomationProperties.AutomationId="terminal-status-badge"
                    Margin="12"
                    Padding="8,5"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{ThemeResource ShellSurfaceBackgroundBrush}"
                    BorderBrush="{ThemeResource ShellBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Visibility="Collapsed">
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource ShellMetaTextStyle}"
                           Text="Starting terminal…" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
